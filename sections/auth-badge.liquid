{%- comment -%}
  Authentication Badge — snippet for product pages showing verification details.
  Can also be used standalone as a trust section on the homepage.
{%- endcomment -%}

<section class="auth-section">
  <div class="section-header">
    <div>
      {%- if section.settings.eyebrow != blank -%}
        <p class="section-eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      <h2 class="section-title">{{ section.settings.heading }}</h2>
    </div>
  </div>

  <div class="auth-grid">
    {%- for block in section.blocks -%}
      <div class="auth-card" {{ block.shopify_attributes }}>
        <div class="auth-card-icon">
          {%- case block.settings.icon -%}
            {%- when 'shield' -%}
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg>
            {%- when 'eye' -%}
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8S1 12 1 12z"/><circle cx="12" cy="12" r="3"/></svg>
            {%- when 'camera' -%}
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M23 19a2 2 0 01-2 2H3a2 2 0 01-2-2V8a2 2 0 012-2h4l2-3h6l2 3h4a2 2 0 012 2z"/><circle cx="12" cy="13" r="4"/></svg>
            {%- when 'certificate' -%}
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M7 8h10M7 12h6M7 16h8"/></svg>
          {%- endcase -%}
        </div>
        <h3 class="auth-card-title">{{ block.settings.title }}</h3>
        <p class="auth-card-desc">{{ block.settings.description }}</p>
      </div>
    {%- endfor -%}
  </div>

  <div class="auth-seal">
    <div class="auth-seal-ring">
      <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4" stroke-width="1.5"/></svg>
    </div>
    <div class="auth-seal-text">
      <span class="auth-seal-brand">First Edition Verified</span>
      <span class="auth-seal-sub">{{ section.settings.seal_text }}</span>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Authentication badge",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "default": "Authenticity Guarantee",
      "label": "Eyebrow text"
    },
    {
      "type": "richtext",
      "id": "heading",
      "default": "<p>Every piece <em>verified</em></p>",
      "label": "Heading"
    },
    {
      "type": "text",
      "id": "seal_text",
      "default": "Inspected, graded & guaranteed authentic",
      "label": "Seal description"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "default": "shield",
          "label": "Icon",
          "options": [
            { "value": "shield", "label": "Shield" },
            { "value": "eye", "label": "Eye" },
            { "value": "camera", "label": "Camera" },
            { "value": "certificate", "label": "Certificate" }
          ]
        },
        { "type": "text", "id": "title", "default": "Step", "label": "Title" },
        { "type": "textarea", "id": "description", "label": "Description" }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Authentication badge",
      "blocks": [
        { "type": "step", "settings": { "icon": "eye", "title": "Expert Inspection", "description": "Every card and game is hand-inspected by our team for authenticity, condition, and centering." } },
        { "type": "step", "settings": { "icon": "camera", "title": "Photo Documentation", "description": "High-resolution photos of front, back, and edges taken under controlled lighting." } },
        { "type": "step", "settings": { "icon": "shield", "title": "Condition Grading", "description": "Graded using our transparent scale from Damaged to Gem Mint with full descriptions." } },
        { "type": "step", "settings": { "icon": "certificate", "title": "Verified Certificate", "description": "Each high-value item includes a First Edition Co verification certificate." } }
      ]
    }
  ]
}
{% endschema %}
