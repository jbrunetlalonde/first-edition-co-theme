<section class="coll-products">
  <div class="coll-toolbar">
    <div class="coll-filters">
      <span class="coll-filter-label">Filter:</span>
      {%- for tag in collection.all_tags limit: 8 -%}
        {%- if current_tags contains tag -%}
          <a href="{{ tag | link_to_remove_tag: tag }}" class="coll-tag coll-tag--active">{{ tag }}</a>
        {%- else -%}
          <a href="{{ tag | link_to_add_tag: tag }}" class="coll-tag">{{ tag }}</a>
        {%- endif -%}
      {%- endfor -%}
    </div>
    <div class="coll-sort">
      <label for="coll-sort-select" class="visually-hidden">Sort by</label>
      <select id="coll-sort-select" class="coll-sort-select" onchange="window.location.href=this.value">
        {%- for option in collection.sort_options -%}
          <option value="{{ option.url }}" {% if collection.sort_by == option.value %}selected{% endif %}>{{ option.name }}</option>
        {%- endfor -%}
      </select>
    </div>
  </div>

  <div class="products-grid">
    {%- for product in collection.products -%}
      <div class="product-card">
        <a href="{{ product.url }}" class="product-card-link">
          <div class="product-img-wrap product-bg-{{ forloop.index | modulo: 4 | plus: 1 }}">
            <div class="product-holo"></div>
            {%- if product.featured_image != blank -%}
              <img
                src="{{ product.featured_image | image_url: width: 400 }}"
                alt="{{ product.featured_image.alt | escape }}"
                loading="lazy"
                width="400"
                height="533"
              >
            {%- endif -%}
          </div>
          <div class="product-info">
            <div class="product-set">{{ product.type }}</div>
            <div class="product-name">{{ product.title }}</div>
            <div class="product-condition">{{ product.metafields.custom.condition }}</div>
            <div class="product-bottom">
              <span class="product-price">{{ product.price | money }}</span>
              {%- if product.metafields.custom.badge != blank -%}
                <span class="product-badge">{{ product.metafields.custom.badge }}</span>
              {%- endif -%}
            </div>
          </div>
        </a>
        <button type="button" class="product-add" data-product-id="{{ product.variants.first.id }}">
          + Add to cart
        </button>
      </div>
    {%- endfor -%}
  </div>

  {%- if paginate.pages > 1 -%}
    <nav class="coll-pagination" aria-label="Pagination">
      {{ paginate | default_pagination: next: '&rarr;', previous: '&larr;' }}
    </nav>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Collection products",
  "tag": "section",
  "settings": [],
  "presets": [
    {
      "name": "Collection products"
    }
  ]
}
{% endschema %}
