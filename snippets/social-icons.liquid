    </a>
  {%- endif -%}

  {%- if settings.social_tiktok != blank -%}
    <a href="{{ settings.social_tiktok }}" class="social-icon social-icon--tiktok" aria-label="TikTok" target="_blank" rel="noopener">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.27 6.27 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.34-6.34V9.41a8.16 8.16 0 004.76 1.52V7.56a4.85 4.85 0 01-1-.87z"/></svg>
    </a>
  {%- endif -%}

  {%- if settings.social_ebay != blank -%}
    <a href="{{ settings.social_ebay }}" class="social-icon social-icon--ebay" aria-label="eBay" target="_blank" rel="noopener">
      <span class="ebay-wordmark"><span style="color:#E53238">e</span><span style="color:#0064D2">b</span><span style="color:#F5AF02">a</span><span style="color:#86B817">y</span></span>
    </a>
  {%- endif -%}

  {%- if settings.social_instagram != blank -%}
    <a href="{{ settings.social_instagram }}" class="social-icon social-icon--instagram" aria-label="Instagram" target="_blank" rel="noopener">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none"/></svg>
    </a>
  {%- endif -%}

  {%- if settings.social_facebook != blank -%}
    <a href="{{ settings.social_facebook }}" class="social-icon social-icon--facebook" aria-label="Facebook" target="_blank" rel="noopener">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
