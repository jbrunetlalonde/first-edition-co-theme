<section class="policy">
  <div class="policy-container">
    {%- if section.settings.eyebrow != blank -%}
      <p class="section-eyebrow">{{ section.settings.eyebrow }}</p>
    {%- endif -%}
    <h1 class="section-title policy-title">{{ section.settings.heading }}</h1>
    {%- if section.settings.updated != blank -%}
      <p class="policy-updated">Last updated: {{ section.settings.updated }}</p>
    {%- endif -%}
    <div class="policy-body">
      {{ section.settings.body }}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Policy page",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Policy"
    },
    {
      "type": "text",
      "id": "updated",
      "label": "Last updated date"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body content"
    }
  ],
  "presets": [
    {
      "name": "Policy page"
    }
  ]
}
{% endschema %}
