<section class="about">
  <div class="about-hero-section">
    {%- if section.settings.image != blank -%}
      <div class="about-hero-img">
        <img src="{{ section.settings.image | image_url: width: 800 }}" alt="{{ section.settings.heading | strip_html | escape }}" width="400" height="500" loading="lazy">
      </div>
    {%- endif -%}
    <div class="about-hero-content">
      {%- if section.settings.eyebrow != blank -%}
        <p class="section-eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      <h1 class="section-title about-title">{{ section.settings.heading }}</h1>
      {%- if section.settings.body != blank -%}
        <div class="about-body">{{ section.settings.body }}</div>
      {%- endif -%}
    </div>
  </div>

  {%- if section.blocks.size > 0 -%}
    <div class="about-values">
      {%- for block in section.blocks -%}
        <div class="about-value" {{ block.shopify_attributes }}>
          <span class="about-value-number">{{ forloop.index | prepend: '0' | slice: -2, 2 }}</span>
          <h3 class="about-value-title">{{ block.settings.title }}</h3>
          <p class="about-value-desc">{{ block.settings.description }}</p>
        </div>
      {%- endfor -%}
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "t:sections.about.name",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "default": "Our Story", "label": "t:sections.about.settings.eyebrow.label" },
    { "type": "richtext", "id": "heading", "default": "<p>Built by <em>collectors,</em> for collectors</p>", "label": "t:sections.about.settings.heading.label" },
    { "type": "richtext", "id": "body", "default": "<p>First Edition Co was born from a lifelong passion for trading cards and retro gaming. What started as a personal collection grew into a mission: to build the most trusted destination for collectors in Quebec and beyond.</p><p>Every item in our inventory is hand-selected, inspected, and graded by our team. We believe collecting should feel special — from the moment you browse to the moment you hold the piece in your hands.</p>", "label": "t:sections.about.settings.body.label" },
    { "type": "image_picker", "id": "image", "label": "t:sections.about.settings.image.label" }
  ],
  "blocks": [
    {
      "type": "value",
      "name": "t:sections.about.blocks.value.name",
      "settings": [
        { "type": "text", "id": "title", "default": "Authenticity", "label": "t:sections.about.blocks.value.settings.title.label" },
        { "type": "textarea", "id": "description", "default": "Every item is verified genuine. No reproductions, no fakes, no exceptions.", "label": "t:sections.about.blocks.value.settings.description.label" }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "t:sections.about.presets.name",
      "blocks": [
        { "type": "value", "settings": { "title": "Authenticity First", "description": "Every item is verified genuine. No reproductions, no fakes, no exceptions." } },
        { "type": "value", "settings": { "title": "Fair Pricing", "description": "We price based on real market data. You'll never overpay for condition or rarity." } },
        { "type": "value", "settings": { "title": "Collector Care", "description": "Museum-grade packaging, insured shipping, and a 14-day return policy on every order." } },
        { "type": "value", "settings": { "title": "Community", "description": "Join thousands of collectors on our Discord. Trade tips, share pulls, and connect." } }
      ]
    }
  ]
}
{% endschema %}
