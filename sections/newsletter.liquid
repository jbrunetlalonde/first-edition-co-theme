<div class="newsletter">
  <div class="newsletter-text">
    {%- if section.settings.heading != blank -%}
      <h3>{{ section.settings.heading }}</h3>
    {%- endif -%}
    {%- if section.settings.description != blank -%}
      <p>{{ section.settings.description }}</p>
    {%- endif -%}
  </div>
  {%- form 'customer', class: 'newsletter-form' -%}
    {%- if form.posted_successfully? -%}
      <p class="newsletter-success" role="status">{{ 'sections.newsletter.success' | t }}</p>
    {%- else -%}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <label for="NewsletterEmail-{{ section.id }}" class="visually-hidden">{{ 'sections.newsletter.email_label' | t }}</label>
      <div class="newsletter-field">
        <input
          id="NewsletterEmail-{{ section.id }}"
          class="newsletter-input"
          type="email"
          name="contact[email]"
          autocomplete="email"
          placeholder="{{ 'sections.newsletter.email_placeholder' | t }}"
          required
        >
        <button type="submit" class="newsletter-btn">{{ 'sections.newsletter.subscribe' | t }}</button>
      </div>
      {%- if form.errors -%}
        <p class="newsletter-error" role="alert">{{ form.errors.messages['email'] | default: form.errors | join: ', ' }}</p>
      {%- endif -%}
    {%- endif -%}
  {%- endform -%}
</div>

{% schema %}
{
  "name": "Newsletter",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "default": "Stay ahead of the drops.",
      "label": "Heading"
    },
    {
      "type": "text",
      "id": "description",
      "default": "New TCG arrivals, retro games and exclusive subscriber deals.",
      "label": "Description"
    }
  ],
  "presets": [
    {
      "name": "Newsletter"
    }
  ]
}
{% endschema %}
